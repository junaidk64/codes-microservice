ENVIRONMENT=development
PORT=4001
APP_PREFIX=/api
APP_NAME=CodesService
DOC_PREFIX=/doc/api

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=admin
MYSQL_NAME=poshtest1

AT_KEY=change-me
AT_EXPIRY=30d

STORAGE_PROVIDER=aws
STORAGE_PATH=./media
STORAGE_LOCAL_URL=http://localhost:4001/api/media/

# MAIN APP PUBLIC API
MAIN_API_BASE_URL=http://localhost:3002
# Must match CODE_MICROSERVICE_AUTH_TOKEN in the main app
MAIN_API_TOKEN=replace-with-main-api-token
MAIN_API_ORDER_GET_PATH=/api/code-microservice/orders/:orderId
MAIN_API_ORDER_UPDATE_PATH=/api/admin/orders/:orderId/codes-generated

STORAGE_S3_BUCKET_NAME=your-bucket
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_AWS_URL=https://your-bucket.s3.amazonaws.com
STORAGE_S3_USE_ACL=false

CODES_SERVICE_TOKEN=change-me
MAIN_SERVICE_URL=http://localhost:4000
